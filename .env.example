# Copy this file to .env and fill in your own values.
# Never commit .env to version control.

# Django Core Settings
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=False

# For local development: ALLOWED_HOSTS=127.0.0.1,localhost
# For production (Render): ALLOWED_HOSTS=127.0.0.1,localhost,your-app-name.onrender.com
ALLOWED_HOSTS=127.0.0.1,localhost

# For production (Render): CSRF_TRUSTED_ORIGINS=https://your-app-name.onrender.com
CSRF_TRUSTED_ORIGINS=

# Groq API  (get your key at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here

